<?php
// ============================================================
// 給与・シフトアプリ（/colorhrm-pay/）DB接続設定（テンプレート）
//   このファイルを config.php にコピーし、ColorHRM と「同じ」MySQLの値を入れる。
//     cp config.php.example config.php
//   ※ ColorHRM と同一DBを共有する（staff / users / pay_rates を直接参照）。
//   ※ config.php は .gitignore 済み（Gitには上げない）。
// ============================================================
return [
  // ColorHRM の config.php と同じ値を入れる（同一DBを共有するため）。
  'db_host'    => 'mysqlXXXX.xserver.jp', // 例: mysql8055.xserver.jp（localhost 不可）
  'db_name'    => 'あなたのDB名',        // ColorHRM と同じDB
  'db_user'    => 'あなたのDBユーザー名',
  'db_pass'    => 'あなたのDBパスワード',
  'db_charset' => 'utf8mb4',

  // ColorHRM（採用・育成）アプリへ戻るリンク先。
  'colorhrm_url' => '/colorhrm/',

  // ============================================================
  // 給与明細の発行通知メール（PHP mail()）。ColorHRM 側と同じ設定でOK。
  //   mail_enabled を false にすると送信しません。from は chishokan.co.jp のアドレスに。
  // ============================================================
  'mail_enabled'   => true,
  'mail_from'      => 'info@chishokan.co.jp',
  'mail_from_name' => '給与・シフト（智翔館）',
  // 通知メール内のリンク基点（給与アプリのURL）。空なら実行URLから自動生成。
  'app_base_url'   => 'https://chishokan.co.jp/colorhrm-pay/',
];
