# ============================================================
# Color HRM (Xサーバー版) .gitignore
# ============================================================

# 実DB認証情報（絶対にコミットしない）。テンプレートは config.php.example を追跡。
config.php

# 初期管理者作成スクリプト（固定パスワードを含むため、実行後は削除推奨）
setup.php

# PHP / 依存
/vendor/
composer.lock

# ログ・一時ファイル
*.log
/logs/
/tmp/
*.tmp

# ローカル検証用スクリーンショット（リポジトリには載せない）
/shots/

# 生成した配布物（Word等）。原本は docs/ の Markdown を正とする
/*.docx

# アップロードされた履歴書（個人情報）は絶対にコミットしない。
# ただし保存先ディレクトリ自体は配置したいので .htaccess / .gitkeep は追跡する。
/uploads/
app/uploads/resumes/*
!app/uploads/resumes/.htaccess
!app/uploads/resumes/.gitkeep
app/uploads/imports/*
!app/uploads/imports/.htaccess
!app/uploads/imports/.gitkeep
app/uploads/evidence/*
!app/uploads/evidence/.htaccess
!app/uploads/evidence/.gitkeep
app/uploads/photos/*
!app/uploads/photos/.htaccess
!app/uploads/photos/.gitkeep

# OS / エディタ
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# tFPDF が実行時に生成する日本語フォントのキャッシュ（絶対パスを含むため非同梱・サーバーで自動生成）
payroll/tfpdf/font/unifont/*.mtx.php
payroll/tfpdf/font/unifont/*.cw127.php
payroll/tfpdf/font/unifont/*.cw.dat
