# ============================================================
# Color HRM (Xサーバー版) .gitignore
# ============================================================

# 実DB認証情報（絶対にコミットしない）。テンプレートは config.php.example を追跡。
config.php

# 初期管理者作成スクリプト（固定パスワードを含むため、実行後は削除推奨）
setup.php

# PHP / 依存
/vendor/
composer.lock

# ログ・一時ファイル
*.log
/logs/
/tmp/
*.tmp

# アップロード（OCR等で扱うファイル：フェーズ4以降）
/uploads/

# OS / エディタ
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
